OPENAI_API_KEY=your_openai_api_key_here

FUND_NAME=Example VC Fund
FUND_GEO_FOCUS=CEE, Europe, diaspora founders
FUND_STAGE_FOCUS=Pre-seed, Seed
FUND_SECTOR_FOCUS=AI, developer tools, infrastructure, SaaS, marketplaces
FUND_TICKET_MIN=500000
FUND_TICKET_MAX=4000000

GMAIL_CREDENTIALS_PATH=/path/to/credentials.json
GMAIL_TOKEN_PATH=/path/to/token.json
GMAIL_PROCESSED_LABEL=Fund/Screened
GMAIL_NEEDS_REVIEW_LABEL=Fund/NeedsReview
GMAIL_USER_EMAIL=your_email@example.com
ALLOWED_SENDER=your_email@example.com
REVIEWER_EMAIL=partner@example.com

POLLING_INTERVAL_MINUTES=15
GATE2_PASS_THRESHOLD=6.0

NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here
NOTION_TASKS_DATABASE_ID=your_notion_tasks_database_id_here

# No Tavily/SerpAPI required. Default: no paid web search (OpenAI-only).
# Optional paid snippets: set TAVILY_API_KEY. To ignore any key: EXTERNAL_WEB_SEARCH=0
# EXTERNAL_WEB_SEARCH=0

# Optional: deterministic HQ resolver (no LLM).
# Uses web-search snippet parsing (typically LinkedIn "Headquarters: ...").
# OFF by default to avoid unexpected paid search usage.
# HQ_RESOLVER=1
# HQ_RESOLVER_MAX_RESULTS=5

# Optional: deterministic Stage resolver (no LLM).
# Uses web-search snippet parsing ("Stage: Seed", "Seed round", etc.).
# OFF by default to avoid unexpected paid search usage.
# STAGE_RESOLVER=1
# STAGE_RESOLVER_MAX_RESULTS=6

# Website mandate: strict geo = block scoring on any geography_match=false (default: only if FAIL_CONFIDENT or HIGH confidence).
# WEBSITE_MANDATE_STRICT_GEOGRAPHY=1
